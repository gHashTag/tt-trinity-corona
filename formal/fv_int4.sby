[tasks]
bmc
prove
cover

[options]
bmc: mode bmc
bmc: depth 1
prove: mode prove
prove: depth 1
cover: mode cover
cover: depth 1

[engines]
smtbmc z3

[script]
read -formal fv_int4.sv
read -formal int4_decode.v
prep -top fv_int4

[files]
fv_int4.sv
../src/rtl/int4_decode.v
