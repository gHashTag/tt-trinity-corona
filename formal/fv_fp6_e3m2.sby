[tasks]
bmc
prove
cover

[options]
bmc: mode bmc
bmc: depth 1
prove: mode prove
prove: depth 1
cover: mode cover
cover: depth 1

[engines]
smtbmc z3

[script]
read -formal fv_fp6_e3m2.sv
read -formal fp6_e3m2_decode.v
prep -top fv_fp6_e3m2

[files]
fv_fp6_e3m2.sv
../src/rtl/fp6_e3m2_decode.v
